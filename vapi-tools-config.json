{
  "_README": "Vapi apiRequest tool definitions for Gabby. Create these in the Vapi Dashboard > Tools, then assign to both EN and AF assistants.",

  "generate_quote": {
    "type": "apiRequest",
    "function": {
      "name": "generate_quote",
      "description": "Generate a quotation for a customer. Use when the customer asks for a quote, price estimate, or proposal. Collect: client name, items with descriptions, quantities, and unit prices. Ask if VAT should be included. Ask if they want it emailed.",
      "parameters": {
        "type": "object",
        "properties": {
          "client_name": { "type": "string", "description": "Customer's full name" },
          "client_email": { "type": "string", "description": "Customer's email address for sending the quote" },
          "client_phone": { "type": "string", "description": "Customer's phone number" },
          "client_company": { "type": "string", "description": "Customer's company name if applicable" },
          "items": {
            "type": "array",
            "description": "Line items for the quote",
            "items": {
              "type": "object",
              "properties": {
                "description": { "type": "string", "description": "Description of the item or service" },
                "quantity": { "type": "number", "description": "Number of units" },
                "unit_price": { "type": "number", "description": "Price per unit in Rands" }
              },
              "required": ["description", "quantity", "unit_price"]
            }
          },
          "include_vat": { "type": "boolean", "description": "Whether to include 15% VAT. Default true." },
          "validity_days": { "type": "number", "description": "How many days the quote is valid. Default 30." },
          "notes": { "type": "string", "description": "Additional notes for the quote" },
          "send_email": { "type": "boolean", "description": "Whether to email the quote to the customer immediately" }
        },
        "required": ["client_name", "items"]
      }
    },
    "method": "POST",
    "url": "https://myaipa.vercel.app/api/document/generate",
    "headers": {
      "Content-Type": "application/json",
      "x-api-key": "{{DOCUMENT_API_SECRET}}"
    },
    "body": {
      "documentType": "QUOTE"
    },
    "messages": [
      { "type": "request-start", "content": "I'm preparing your quotation now." },
      { "type": "request-complete", "content": "Your quotation is ready." },
      { "type": "request-failed", "content": "I'm sorry, I wasn't able to generate the quotation. Let me try again." }
    ]
  },

  "generate_invoice": {
    "type": "apiRequest",
    "function": {
      "name": "generate_invoice",
      "description": "Generate a tax invoice for a customer. Use when the customer confirms an order, or when converting a quote to an invoice. Collect: client name, items with descriptions, quantities, and unit prices, payment terms.",
      "parameters": {
        "type": "object",
        "properties": {
          "client_name": { "type": "string", "description": "Customer's full name" },
          "client_email": { "type": "string", "description": "Customer's email address" },
          "client_phone": { "type": "string", "description": "Customer's phone number" },
          "client_company": { "type": "string", "description": "Customer's company name" },
          "items": {
            "type": "array",
            "description": "Line items for the invoice",
            "items": {
              "type": "object",
              "properties": {
                "description": { "type": "string" },
                "quantity": { "type": "number" },
                "unit_price": { "type": "number" }
              },
              "required": ["description", "quantity", "unit_price"]
            }
          },
          "include_vat": { "type": "boolean" },
          "payment_terms": { "type": "string", "description": "e.g. 'Due on receipt', 'Net 30'" },
          "due_date": { "type": "string", "description": "Due date in YYYY-MM-DD format" },
          "notes": { "type": "string" },
          "send_email": { "type": "boolean" }
        },
        "required": ["client_name", "items"]
      }
    },
    "method": "POST",
    "url": "https://myaipa.vercel.app/api/document/generate",
    "headers": {
      "Content-Type": "application/json",
      "x-api-key": "{{DOCUMENT_API_SECRET}}"
    },
    "body": {
      "documentType": "INVOICE"
    },
    "messages": [
      { "type": "request-start", "content": "I'm generating your invoice now." },
      { "type": "request-complete", "content": "Your invoice is ready." },
      { "type": "request-failed", "content": "I wasn't able to generate the invoice right now." }
    ]
  },

  "convert_quote_to_invoice": {
    "type": "apiRequest",
    "function": {
      "name": "convert_quote_to_invoice",
      "description": "Convert an existing quotation into a tax invoice. Use when a customer says they accept a quote or want to proceed with a quoted price. You need the quote number.",
      "parameters": {
        "type": "object",
        "properties": {
          "convert_from_quote": { "type": "string", "description": "The quote number to convert, e.g. Q00051" },
          "payment_terms": { "type": "string", "description": "Payment terms for the invoice" },
          "due_date": { "type": "string", "description": "Due date in YYYY-MM-DD format" },
          "send_email": { "type": "boolean" }
        },
        "required": ["convert_from_quote"]
      }
    },
    "method": "POST",
    "url": "https://myaipa.vercel.app/api/document/generate",
    "headers": {
      "Content-Type": "application/json",
      "x-api-key": "{{DOCUMENT_API_SECRET}}"
    },
    "body": {},
    "messages": [
      { "type": "request-start", "content": "I'm converting your quote to an invoice." },
      { "type": "request-complete", "content": "Done. Your invoice has been created from the quote." },
      { "type": "request-failed", "content": "I couldn't convert the quote. Please check the quote number." }
    ]
  },

  "send_email": {
    "_note": "Already working. Config reference only.",
    "type": "apiRequest",
    "function": {
      "name": "send_email",
      "description": "Send an email on behalf of the business. Use when a customer asks you to email them information, a document, or a follow-up.",
      "parameters": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "Recipient email address" },
          "subject": { "type": "string", "description": "Email subject line" },
          "body": { "type": "string", "description": "Email body text" }
        },
        "required": ["to", "subject", "body"]
      }
    },
    "method": "POST",
    "url": "https://myaipa.vercel.app/api/email/send",
    "headers": {
      "Content-Type": "application/json",
      "x-api-key": "{{EMAIL_API_SECRET}}"
    },
    "body": {},
    "messages": [
      { "type": "request-start", "content": "I'm sending the email now." },
      { "type": "request-complete", "content": "The email has been sent." },
      { "type": "request-failed", "content": "I wasn't able to send the email right now." }
    ]
  },

  "send_whatsapp": {
    "_note": "Waiting for Meta approval. Configure once approved.",
    "type": "apiRequest",
    "function": {
      "name": "send_whatsapp",
      "description": "Send a WhatsApp message to a customer. Use when they ask to be contacted via WhatsApp or when sending documents via WhatsApp.",
      "parameters": {
        "type": "object",
        "properties": {
          "to": { "type": "string", "description": "Recipient phone number in international format e.g. +27821234567" },
          "body": { "type": "string", "description": "Message text" }
        },
        "required": ["to", "body"]
      }
    },
    "method": "POST",
    "url": "https://myaipa.vercel.app/api/whatsapp/send",
    "headers": {
      "Content-Type": "application/json",
      "x-api-key": "{{WHATSAPP_API_SECRET}}"
    },
    "body": {},
    "messages": [
      { "type": "request-start", "content": "Sending your WhatsApp message now." },
      { "type": "request-complete", "content": "WhatsApp message sent." },
      { "type": "request-failed", "content": "I couldn't send the WhatsApp message right now." }
    ]
  }
}
